{
  "manifest_version": 4,
  "name": "TRPG Character Maker",
  "version": "1.0.3",
  "permissions": [ "tabs" ],
  "description": "TRPG Character Generator that can be associated with Cocoporia and Google Sheets",
  "icons": {
    "16": "16image.png",
    "48": "48image.png",
    "128": "128image.png"
  },
  "action": {
    "default_popup": "index.html",
    "default_icon": "16image.png",
    "default_title": "TRPG Character Maker"
  }
}